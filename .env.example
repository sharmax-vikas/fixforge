# Required for live Codex analysis
OPENAI_API_KEY=
# Select an available Codex-capable model for your account.
OPENAI_MODEL=gpt-5.3-codex
# Maximum supported reasoning setting for the default Codex model.
OPENAI_REASONING_EFFORT=xhigh

# Set to true for a fully local product demo with no OpenAI call.
FIXLY_DEMO_MODE=false
# Use local, evidence-based analysis and skip OpenAI calls.
FIXLY_ANALYSIS_MODE=local

# Optional: increases GitHub API rate limits and lets Fixly read private repositories.
GITHUB_TOKEN=

# Required only for the final draft-PR step. This must be your fork of the
# repository named in the issue URL; FixForge never pushes to upstream.
FIXFORGE_FORK_REPOSITORY=

# Maximum time for one candidate's focused test command.
TEST_TIMEOUT_SECONDS=180

# Optional server port
PORT=8000
